{
    "name": "sfmc-extension-pack",
    "displayName": "SFMC Extension Pack",
    "description": "Installs Salesforce Marketing Cloud Engagement extensions: SFMC Data Loader, SFMC DevTools, and SFMC Language Service.",
    "version": "0.1.0",
    "publisher": "joernberkefeld",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/JoernBerkefeld/vscode-sfmc-extension-pack.git"
    },
    "bugs": {
        "url": "https://github.com/JoernBerkefeld/vscode-sfmc-extension-pack/issues"
    },
    "engines": {
        "vscode": "^1.101.0"
    },
    "categories": [
        "Extension Packs"
    ],
    "keywords": [
        "sfmc",
        "salesforce",
        "marketing cloud",
        "extension pack"
    ],
    "icon": "resources/images/pack-v2-transparent-256.png",
    "galleryBanner": {
        "color": "#032d60",
        "theme": "dark"
    },
    "main": "./extension.js",
    "extensionPack": [
        "joernberkefeld.sfmc-data",
        "Accenture-oss.sfmc-devtools-vscode",
        "joernberkefeld.sfmc-language"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "contributes": {},
    "scripts": {
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "prepare": "husky || true",
        "test": "node --test test/*.test.mjs",
        "vscode:prepublish": "node -e \"require('fs').accessSync('extension.js')\"",
        "package": "npx @vscode/vsce package"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@vscode/vsce": "^3.7.1",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsdoc": "^62.0.0",
        "eslint-plugin-prettier": "^5.5.0",
        "eslint-plugin-unicorn": "^64.0.0",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.5",
        "prettier": "^3.8.1"
    },
    "lint-staged": {
        "*.{js,mjs,cjs}": [
            "eslint --fix"
        ]
    }
}
